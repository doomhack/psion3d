module videomem

segment _TEXT(CODE,48H)

public _disableMemProtection:
	xor	al,al
	out	15H,al
	ret 0

public _enableMemProtection:
	xor	al,al
	out	14H,al
	ret 0

public _pokeVideoMem:
	push  bp
	mov   bp,sp
	sub   sp,4
	push  bx
	push  es
	xor   bx,bx
	mov   word [bp][-2],40H
	call  near _disableMemProtection
	mov   es,[bp][-2]
	mov   byte es:[bx],-1
	call  near _enableMemProtection
	pop   es
	pop   bx
	mov   sp,bp
	pop   bp
	ret 0 


end
