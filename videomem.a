module videomem

segment _TEXT(CODE,48H)

public _disableMemProtection:
	xor	al,al
	out	15H,al
	ret 0

public _enableMemProtection:
	xor	al,al
	out	14H,al
	ret 0

public _blitVideoMem:
	push  bp
	mov   bp,sp
	sub   sp,2
	mov   [bp][-2],ax
	push  ax
	push  bx
	push  cx
	push  dx
	push  si
	push  di

	cli

	pushf
	push  es
	mov   ax,40H
	mov   es,ax


	call  near _disableMemProtection
	cld

	mov   si,[bp][-2]
	mov   di,15
	mov   bx,160
blitPackedRow:
	mov   cx,32
blitPackedByte:
	lodsw
	mov   dx,ax
	and   ax,0F0FH
	shl   ah,1
	shl   ah,1
	shl   ah,1
	shl   ah,1
	or    al,ah
	stosb
	mov   ax,dx
	and   ax,0F0F0H
	shr   al,1
	shr   al,1
	shr   al,1
	shr   al,1
	or    al,ah
	mov   es:[di] [9599],al
	loop  blitPackedByte
	add   di,28
	dec   bx
	jne   blitPackedRow

	call  near _enableMemProtection
	pop   es
	popf

	sti

	pop   di
	pop   si
	pop   dx
	pop   cx
	pop   bx
	pop   ax
	mov   sp,bp
	pop   bp
	ret 0

end
