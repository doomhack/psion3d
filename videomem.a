module videomem

segment _TEXT(CODE,48H)

public _disableMemProtection:
	xor	al,al
	out	15H,al
	ret 0

public _enableMemProtection:
	xor	al,al
	out	14H,al
	ret 0

public _blitVideoMem:
	push  bp
	mov   bp,sp
	sub   sp,4
	mov   [bp][-2],ax
	mov   [bp][-4],bx
	push  ax
	push  bx
	push  cx
	push  dx
	push  si
	push  di

	cli

	pushf
	push  es
	mov   ax,40H
	mov   es,ax


	call  near _disableMemProtection
	cld

	mov   si,[bp][-2]
	mov   di,15
	mov   dx,160
blitBlackRow:
	mov   cx,16
	rep;  movsw
	add   di,28
	dec   dx
	jne   blitBlackRow

	mov   si,[bp][-4]
	mov   di,9615
	mov   dx,160
blitGreyRow:
	mov   cx,16
	rep;  movsw
	add   di,28
	dec   dx
	jne   blitGreyRow

	call  near _enableMemProtection
	pop   es
	popf

	sti

	pop   di
	pop   si
	pop   dx
	pop   cx
	pop   bx
	pop   ax
	mov   sp,bp
	pop   bp
	ret 0

end
